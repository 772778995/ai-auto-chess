{
  "name": "@game/server",
  "version": "0.1.0",
  "private": true,
  "description": "Game server with Hono.js and WebSocket support",
  "type": "module",
  "main": "./dist/main.js",
  "scripts": {
    "dev": "bun --watch src/main.ts",
    "build": "bun run build:tsc",
    "build:tsc": "tsc",
    "start": "NODE_ENV=production bun dist/main.js",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "db:push": "drizzle-kit push"
  },
  "dependencies": {
    "@game/shared": "workspace:*",
    "@hono/node-server": "^1.11.4",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.40.0",
    "drizzle-zod": "^0.6.0",
    "hono": "^4.4.7",
    "jsondiffpatch": "^0.7.3",
    "msgpackr": "^1.11.9",
    "postgres": "^3.4.4",
    "redis": "^5.11.0",
    "ws": "^8.16.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/ws": "^8.5.10",
    "@types/node": "^20.11.24",
    "drizzle-kit": "^0.30.0",
    "typescript": "^5.6.3",
    "vitest": "^2.0.5",
    "oxlint": "^0.16.0"
  }
}